# ── MT5 Connection ────────────────────────────────────────────────────────────
MT5_LOGIN=7386248
MT5_PASSWORD=OmnivinFP@1
MT5_SERVER=FPMarketsSC-Demo
# Full path to terminal64.exe on your machine
